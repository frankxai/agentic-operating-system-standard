{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://frankxai.github.io/agentic-operating-system-standard/schemas/module.schema.json",
  "title": "Agentic Operating System Module",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "name",
    "buyer",
    "purpose",
    "first_workflow",
    "agents",
    "skills",
    "workflows",
    "loops",
    "approval_gates",
    "proof_artifact",
    "visibility"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
    "name": { "type": "string", "minLength": 3 },
    "buyer": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "purpose": { "type": "string", "minLength": 20 },
    "first_workflow": { "type": "string", "minLength": 10 },
    "agents": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "skills": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "workflows": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "loops": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "approval_gates": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "proof_artifact": { "type": "string", "minLength": 10 },
    "visibility": { "type": "string", "enum": ["public", "private", "private-pro", "proposed"] },
    "repo": { "type": "string" }
  }
}
