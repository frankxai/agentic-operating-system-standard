  "contracts": {
    "moduleSchema": "schemas/module.schema.json",
    "agentContractSchema": "schemas/agent-contract.schema.json",
    "workflowSchema": "schemas/workflow.schema.json",
    "moduleTemplate": "templates/module-charter.md",
    "agentTemplate": "templates/agent-contract.md",
    "skillTemplate": "templates/skills.md",
    "workflowTemplate": "templates/workflow.md",
    "handoffTemplate": "templates/handoff-packet.md"
