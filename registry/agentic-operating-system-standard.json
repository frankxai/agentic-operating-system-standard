      "repo": "https://github.com/frankxai/agentic-investor-os",
      "visibility": "proposed"
    },
    {
      "id": "domain-intelligence",
      "name": "Domain Intelligence System",
      "doc": "modules/domain-intelligence.md",
      "firstWorkflow": "candidate-to-verification-to-decision-ledger",
      "repo": "https://github.com/frankxai/domain-intelligence-system",
      "visibility": "private-pro"
    },
    {
      "id": "asset-intelligence",
      "name": "Agentic Asset Intelligence",
      "doc": "modules/asset-intelligence.md",
      "firstWorkflow": "surface-to-asset-thesis-to-ledger",
      "repo": "https://github.com/frankxai/agentic-asset-intelligence-system",
      "visibility": "proposed"
    }
