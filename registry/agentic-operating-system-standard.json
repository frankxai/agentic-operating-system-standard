    },
    {
      "id": "ais",
      "name": "Agent Intelligence System",
      "role": "discovery-and-routing",
      "repo": "https://github.com/frankxai/Agent-Intelligence-System"
    },
    {
      "id": "acos",
      "name": "Agentic Creator OS",
      "role": "creator-execution-substrate",
      "repo": "https://github.com/frankxai/agentic-creator-os"
    }
  ],
  "modules": [
    {
      "id": "creator-os",
      "name": "Agentic Creator OS",
